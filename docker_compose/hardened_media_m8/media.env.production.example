# Copy to media.env.production — media_service PRODUCTION configuration.
#
# Used by the production overlay (docker-compose.production.yml), which mounts
# this file in place of media.env:
#   docker compose -f docker-compose.yml -f docker-compose.production.yml up -d
#
# ── Secrets are NOT set here — they arrive via _FILE env vars ─────────────────
# The production overlay mounts each secret from ./secrets/<name>.txt under
# /run/secrets/ and injects the corresponding *_FILE environment variable.
# auth-sdk-m8's CommonSettings resolves *_FILE before the .env on disk, so the
# value never appears in `docker inspect`.
#
# Secrets sourced from /run/secrets/ (set in docker-compose.production.yml):
#   DB_PASSWORD                   → DB_PASSWORD_FILE=/run/secrets/db_password
#   MEDIA_REDIS_PASSWORD          → MEDIA_REDIS_PASSWORD_FILE=/run/secrets/media_redis_password
#   MEDIA_INTERNAL_SERVICE_TOKEN  → MEDIA_INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/media_internal_service_token
#   MEDIA_SHARE_SIGNING_SECRET    → MEDIA_SHARE_SIGNING_SECRET_FILE=/run/secrets/media_share_signing_secret
#   MINIO_ACCESS_KEY              → MINIO_ACCESS_KEY_FILE=/run/secrets/minio_access_key
#   MINIO_SECRET_KEY              → MINIO_SECRET_KEY_FILE=/run/secrets/minio_secret_key
#   PRIVATE_API_SECRET            → PRIVATE_API_SECRET_FILE=/run/secrets/private_api_secret
#   REFRESH_SECRET_KEY            → REFRESH_SECRET_KEY_FILE=/run/secrets/refresh_secret_key
#   EVENT_SIGNING_KEY             → EVENT_SIGNING_KEY_FILE=/run/secrets/event_signing_key

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=media.example.com
ENVIRONMENT=production
# Make every production safety check fatal (fail closed) rather than warn.
STRICT_PRODUCTION_MODE=true
PROJECT_NAME=M8MediaService
STACK_NAME=m8-media-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/media
SET_OPEN_API=false
SET_DOCS=false
SET_REDOC=false

# ── Host allowlist (app-layer guard — fatal under strict if empty) ─────────────
# Keep in sync with the Traefik Host(...) rule in traefik/production_dynamic_conf.yml.
ALLOWED_HOSTS=media.example.com

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=https://media.example.com
FRONTEND_HOST=https://app.example.com
BACKEND_CORS_ORIGINS=https://app.example.com

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_PASSWORD is sourced from /run/secrets/db_password via DB_PASSWORD_FILE.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=media_db
DB_USER=changethis

# ── Media Redis (MinIO presign cache) ────────────────────────────────────────
# MEDIA_REDIS_PASSWORD is sourced from /run/secrets/media_redis_password via MEDIA_REDIS_PASSWORD_FILE.
MEDIA_REDIS_HOST=media_redis_cache
MEDIA_REDIS_PORT=6379
MEDIA_REDIS_USER=media
MEDIA_REDIS_NAMESPACE=media

# ── Internal service auth ─────────────────────────────────────────────────────
# MEDIA_INTERNAL_SERVICE_TOKEN is sourced from /run/secrets/media_internal_service_token
# via MEDIA_INTERNAL_SERVICE_TOKEN_FILE.

# ── Share links ───────────────────────────────────────────────────────────────
# MEDIA_SHARE_SIGNING_SECRET is sourced from /run/secrets/media_share_signing_secret
# via MEDIA_SHARE_SIGNING_SECRET_FILE.
MEDIA_SHARE_DEFAULT_EXPIRES_SECONDS=604800
MEDIA_SHARE_MAX_EXPIRES_SECONDS=2592000

# ── MinIO ─────────────────────────────────────────────────────────────────────
# MINIO_ACCESS_KEY is sourced from /run/secrets/minio_access_key via MINIO_ACCESS_KEY_FILE.
# MINIO_SECRET_KEY is sourced from /run/secrets/minio_secret_key via MINIO_SECRET_KEY_FILE.
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
MINIO_BUCKET_PUBLIC=public-media
MINIO_BUCKET_PRIVATE=private-media
MINIO_BUCKET_SENSITIVE=sensitive-media
MINIO_BUCKET_TEMP=temp-media
MINIO_BUCKET_ARCHIVE=archive-media
MINIO_PRESIGNED_URL_EXPIRE_SECONDS=300
# Replace with your production storage FQDN; must match the Traefik Host rule.
MINIO_PUBLIC_ENDPOINT=https://storage.example.com
MEDIA_MAX_UPLOAD_SIZE_BYTES=104857600

# ── Storage quotas ───────────────────────────────────────────────────────────
# MEDIA_DEFAULT_QUOTA_BYTES=10737418240
# MEDIA_DEFAULT_QUOTA_OBJECTS=10000

# ── Lifecycle / retention ─────────────────────────────────────────────────────
MEDIA_RETENTION_PURGE_DAYS=30
MEDIA_PURGE_BATCH_LIMIT=500
MEDIA_RECONCILE_GRACE_MINUTES=60
MEDIA_RECONCILE_BATCH_LIMIT=1000
MEDIA_PURGE_CRON_HOUR=3
MEDIA_STALE_CRON_MINUTE=15

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
# REFRESH_SECRET_KEY is sourced from /run/secrets/refresh_secret_key via REFRESH_SECRET_KEY_FILE.
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims — REQUIRED (fatal under strict) ─────────────────────
TOKEN_STRICT_VALIDATION=true
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://api.example.com

# ── Token revocation ─────────────────────────────────────────────────────────
# PRIVATE_API_SECRET is sourced from /run/secrets/private_api_secret via PRIVATE_API_SECRET_FILE.
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
ACCESS_REVOCATION_FAILURE_MODE=fail_closed

# ── Per-consumer internal auth (9.1) ─────────────────────────────────────────
INTERNAL_CLIENT_ID=media-service
# SERVICE_TOKEN_EXCHANGE_ENABLED=false

# ── Event signing ─────────────────────────────────────────────────────────────
# EVENT_SIGNING_KEY is sourced from /run/secrets/event_signing_key via EVENT_SIGNING_KEY_FILE.
EVENT_SIGNING_ENABLED=true
# Accepting unsigned events is FATAL under production/strict — leave unset/false.
#EVENT_SIGNING_ACCEPT_UNSIGNED=false

# ── Auth event stream ─────────────────────────────────────────────────────────
REVOCATION_CACHE_TTL_SECONDS=30

# ── Rate-limiter Redis-error policy ──────────────────────────────────────────
MEDIA_RATE_LIMIT_FAILURE_MODE=fail_closed

# ── Proxy trust ───────────────────────────────────────────────────────────────
TRUSTED_PROXY_COUNT=1

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all
# Optional bearer credential for /metrics — source from /run/secrets/ via _FILE:
#   METRICS_SCRAPE_CREDENTIAL_FILE=/run/secrets/metrics_scrape_credential

# ── Health detail gating (item 9.3) ──────────────────────────────────────────
# Source from /run/secrets/ via _FILE rather than setting plaintext here.
# Add to docker-compose.production.yml secrets block and wire:
#   HEALTH_DETAIL_CREDENTIAL_FILE=/run/secrets/health_detail_credential
# Unset (default) = detail body never shown (fail-closed). Must NOT equal PRIVATE_API_SECRET.

# ── Response security headers ─────────────────────────────────────────────────
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=
