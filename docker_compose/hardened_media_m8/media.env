# Copy to media.env and replace every "changethis" with real values.
# Token verification uses JWKS — no private key or ACCESS_SECRET_KEY needed.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=localhost
ENVIRONMENT=local
PROJECT_NAME=M8MediaService
STACK_NAME=m8-media-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/media
SET_OPEN_API=true
SET_DOCS=true
SET_REDOC=true

# ── Service paths ─────────────────────────────────────────────────────────────

# ── CORS / Frontend ───────────────────────────────────────────────────────────
BACKEND_HOST=http://127.0.0.1:9000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:9000,https://localhost,https://localhost:9000,https://localhost:5173

# ── Service role & auth routing ───────────────────────────────────────────────
AUTH_SERVICE_ROLE=consumer
AUTH_PREFIX=/user

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_USER must match MEDIA_DB_USER in .env; DB_PASSWORD must match MEDIA_DB_PASSWORD.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=media_db
DB_USER=media_user
DB_PASSWORD=Ocoti173Media1@

# ── Media Redis (MinIO presign cache) ────────────────────────────────────────
MEDIA_REDIS_HOST=media_redis_cache
MEDIA_REDIS_PORT=6379
MEDIA_REDIS_USER=appuser
MEDIA_REDIS_PASSWORD=DIgPboekHSbjl7JG5ZGVQ2ayBiLYsdcEI1ljaayDe9Prx0xiQwFPrSa7H--2RUF7
MEDIA_REDIS_NAMESPACE=media

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1
MINIO_ACCESS_KEY=media_rw_user
MINIO_SECRET_KEY=Ocoti173MediaMinio1@
MINIO_BUCKET_PUBLIC=public-media
MINIO_BUCKET_PRIVATE=private-media
MINIO_BUCKET_SENSITIVE=sensitive-media
MINIO_BUCKET_TEMP=temp-media
MINIO_BUCKET_ARCHIVE=archive-media
MINIO_PRESIGNED_URL_EXPIRE_SECONDS=300
MEDIA_MAX_UPLOAD_SIZE_BYTES=104857600

# ── Token verification — RS256 via JWKS ──────────────────────────────────────
ACCESS_TOKEN_ALGORITHM=RS256
JWKS_URI=http://auth_user_service:8000/user/.well-known/jwks.json
JWKS_CACHE_TTL_SECONDS=300
REFRESH_SECRET_KEY=z8c1bxk4l8a9abn_bndfg454gdfg4dg54KJJHHdcnDZRZRZ87dfs-hkg21ghk84k6g54df5s4s65az6a5r46ze5r46jl_j5l4w3wx4c5c3w2v1wa6h43m32vw2sdqd21cvw65
REFRESH_TOKEN_ALGORITHM=HS256
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token revocation (stateful consumer) ─────────────────────────────────────
INTROSPECTION_URL=http://auth_user_service:8000/user/private/v1/jti-status
PRIVATE_API_SECRET=w3c1bxk4l8a9a3svcvx1bxncn8-7dfshkg21gLKJLKhk84k6gA54df5s4s65az6a_5r46ze5r46jlj5_l4w3wx4c5c3w2v1wa6h43m32vw2sdqd21cvw65fg58t

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all
