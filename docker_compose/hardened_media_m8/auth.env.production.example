# Copy to auth.env.production — auth_user_service PRODUCTION configuration.
#
# Used by the production overlay (docker-compose.production.yml), which mounts
# this file in place of auth.env:
#   docker compose -f docker-compose.yml -f docker-compose.production.yml up -d
#
# ── Secrets are NOT set here — they arrive via _FILE env vars ─────────────────
# The production overlay mounts each secret from ./secrets/<name>.txt under
# /run/secrets/ and injects the corresponding *_FILE environment variable.
# auth-sdk-m8's CommonSettings resolves *_FILE before the .env on disk, so the
# value never appears in `docker inspect`.
#
# Secrets sourced from /run/secrets/ (set in docker-compose.production.yml):
#   DB_PASSWORD          → DB_PASSWORD_FILE=/run/secrets/db_password
#   REDIS_PASSWORD       → REDIS_PASSWORD_FILE=/run/secrets/auth_redis_password
#   PRIVATE_API_SECRET   → PRIVATE_API_SECRET_FILE=/run/secrets/private_api_secret
#   REFRESH_SECRET_KEY   → REFRESH_SECRET_KEY_FILE=/run/secrets/refresh_secret_key
#   EVENT_SIGNING_KEY    → EVENT_SIGNING_KEY_FILE=/run/secrets/event_signing_key
#   SESSION_SECRET       → SESSION_SECRET_FILE=/run/secrets/session_secret
#   TOKENS_ENCRYPTION_KEY→ TOKENS_ENCRYPTION_KEY_FILE=/run/secrets/tokens_encryption_key
#
# All other secrets (FIRST_SUPERUSER_PASSWORD, ACCESS_KEY_ID) remain in this
# file as `changethis` placeholders — the service FAILS CLOSED until replaced.

# ── Identity ──────────────────────────────────────────────────────────────────
DOMAIN=auth.example.com
ENVIRONMENT=production
# Make every production safety check fatal (fail closed) rather than warn.
STRICT_PRODUCTION_MODE=true
PROJECT_NAME=MyAuthService
STACK_NAME=my-auth-service

# ── API & docs ────────────────────────────────────────────────────────────────
API_PREFIX=/user
# Docs OFF in production. Flip SERVE_DOCS_IN_PRODUCTION=true only for a public,
# open-source API (emits a startup warning); never for a private deployment.
SET_OPEN_API=false
SET_DOCS=false
SET_REDOC=false
#SERVE_DOCS_IN_PRODUCTION=false

# ── Host allowlist (app-layer guard — fatal under strict if empty) ─────────────
# TrustedHostMiddleware rejects any Host header not listed here. Must include the
# public FQDN(s) this service answers on. Keep in sync with the Traefik Host(...)
# rule in traefik/production_dynamic_conf.yml.
ALLOWED_HOSTS=auth.example.com

# ── CORS / Frontend (no localhost origins in production) ───────────────────────
BACKEND_HOST=https://auth.example.com
FRONTEND_HOST=https://app.example.com
BACKEND_CORS_ORIGINS=https://app.example.com

# ── Session cookie ─────────────────────────────────────────────────────────────
# HTTPS-only stack → cookies must be Secure.
SESSION_COOKIE_SECURE=true

# ── Service role ──────────────────────────────────────────────────────────────
AUTH_SERVICE_ROLE=issuer

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DB_PASSWORD is sourced from /run/secrets/db_password via DB_PASSWORD_FILE.
SELECTED_DB=Postgres
DB_HOST=m8_db
DB_PORT=5432
DB_DATABASE=auth_db
DB_USER=changethis_auth_user

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD is sourced from /run/secrets/auth_redis_password via REDIS_PASSWORD_FILE.
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_USER=auth

# ── RS256 asymmetric signing — keys volume-mounted from ./keys:/opt/keys:ro ──
ACCESS_TOKEN_ALGORITHM=RS256
REFRESH_TOKEN_ALGORITHM=HS256
ACCESS_PRIVATE_KEY_FILE=/opt/keys/private.pem
ACCESS_PUBLIC_KEY_FILE=/opt/keys/public.pem
# Optional: stable kid for JWKS (auto-derived from key fingerprint if unset).
ACCESS_KEY_ID=changethis_hex_kid
# REFRESH_SECRET_KEY is sourced from /run/secrets/refresh_secret_key via REFRESH_SECRET_KEY_FILE.
#REFRESH_SECRET_KEY_OLD=
TOKEN_MODE=stateful
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Token boundary claims — REQUIRED (fatal under strict) ─────────────────────
# Real, public, stable values — the issuer/audience your consumers verify.
TOKEN_STRICT_VALIDATION=true
TOKEN_ISSUER=https://auth.example.com
TOKEN_AUDIENCE=https://api.example.com

# ── Auth-service-only (non-secret) fields ─────────────────────────────────────
# PRIVATE_API_SECRET → PRIVATE_API_SECRET_FILE (sourced from /run/secrets/).
# SESSION_SECRET     → SESSION_SECRET_FILE     (sourced from /run/secrets/).
# TOKENS_ENCRYPTION_KEY → TOKENS_ENCRYPTION_KEY_FILE (sourced from /run/secrets/).
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── Per-consumer private-API credentials (9.1, recommended in production) ──────
# Replaces the single shared PRIVATE_API_SECRET on the private routes with
# per-consumer, scoped credentials. Source the JSON via PRIVATE_API_CONSUMERS_FILE
# if using Docker secrets.
#PRIVATE_API_CONSUMERS={"media-service":{"secret":"sha256$changethis","scopes":["introspection","event-stream"]}}
#SERVICE_TOKEN_TTL_SECONDS=300

# ── Event signing (fail-closed when enabled) ──────────────────────────────────
# EVENT_SIGNING_KEY is sourced from /run/secrets/event_signing_key via EVENT_SIGNING_KEY_FILE.
EVENT_SIGNING_ENABLED=true
# Accepting unsigned events is FATAL under production/strict — leave unset/false.
#EVENT_SIGNING_ACCEPT_UNSIGNED=false
EVENT_STREAM_ENABLED=true
EVENT_STREAM_BUFFER_SIZE=256
EVENT_STREAM_HEARTBEAT_SECONDS=15
EVENT_STREAM_MAX_QUEUE=64

# ── Hardened degradation policy (fail closed) ─────────────────────────────────
AUTH_STRICT_MODE=true
RATE_LIMIT_FAILURE_MODE=fail_closed
ACCESS_REVOCATION_FAILURE_MODE=fail_closed
#REFRESH_VALIDATION_FAILURE_MODE=fail_closed
#SESSION_WRITE_FAILURE_MODE=fail_closed

# ── Proxy trust ───────────────────────────────────────────────────────────────
# One Traefik instance in front of this service.
TRUSTED_PROXY_COUNT=1

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_GROUPS=all
# /metrics is internal-only by default (network boundary is the primary control).
# Set a scrape credential ONLY if metrics must cross a less-trusted boundary.
#METRICS_SCRAPE_CREDENTIAL=changethis

# ── Response security headers ─────────────────────────────────────────────────
# HSTS is browser-persisted and hard to reverse — opt-in even in production.
# Enable only once TLS is stable on a trusted, stable certificate.
#HSTS_ENABLED=false
#CONTENT_SECURITY_POLICY_ENABLED=false
#HSTS_MAX_AGE=31536000
#HSTS_INCLUDE_SUBDOMAINS=true
#CONTENT_SECURITY_POLICY=
