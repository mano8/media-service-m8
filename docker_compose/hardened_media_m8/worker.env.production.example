# Copy to worker.env.production — media-worker-m8 PRODUCTION configuration.
#
# Used by the production overlay (docker-compose.production.yml), which mounts
# this file in place of worker.env:
#   docker compose -f docker-compose.yml -f docker-compose.production.yml up -d
#
# ── Secrets are NOT set here — they arrive via _FILE env vars ─────────────────
# The production overlay mounts each secret from ./secrets/<name>.txt under
# /run/secrets/ and injects the corresponding *_FILE environment variable.
#
# Secrets sourced from /run/secrets/ (set in docker-compose.production.yml):
#   MEDIA_INTERNAL_SERVICE_TOKEN → MEDIA_INTERNAL_SERVICE_TOKEN_FILE=/run/secrets/media_internal_service_token
#   MEDIA_REDIS_PASSWORD         → MEDIA_REDIS_PASSWORD_FILE=/run/secrets/media_redis_password
#   MINIO_ACCESS_KEY             → MINIO_ACCESS_KEY_FILE=/run/secrets/minio_access_key
#   MINIO_SECRET_KEY             → MINIO_SECRET_KEY_FILE=/run/secrets/minio_secret_key

# ── Media-service internal API ───────────────────────────────────────────────
# In-cluster URL; worker appends /v1/internal/...
# MEDIA_INTERNAL_SERVICE_TOKEN is sourced from /run/secrets/ via _FILE.
MEDIA_API_URL=http://media_service:8000/media

# ── Media Redis (ARQ queue) ──────────────────────────────────────────────────
# MEDIA_REDIS_PASSWORD is sourced from /run/secrets/ via _FILE.
MEDIA_REDIS_HOST=media_redis_cache
MEDIA_REDIS_PORT=6379
MEDIA_REDIS_USER=media
MEDIA_REDIS_NAMESPACE=media

# ── MinIO / object storage ───────────────────────────────────────────────────
# MINIO_ACCESS_KEY and MINIO_SECRET_KEY are sourced from /run/secrets/ via _FILE.
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=eu-west-1

# ── ClamAV daemon ────────────────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
